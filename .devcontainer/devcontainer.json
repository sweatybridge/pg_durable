{
  "name": "pg_durable Development",
  "image": "mcr.microsoft.com/devcontainers/rust:1-bookworm",
  
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git-lfs:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "rust-analyzer.cargo.features": ["pg17"],
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.check.extraArgs": ["--features", "pg17"]
      }
    }
  },

  // onCreateCommand runs during Codespaces prebuild (heavy setup)
  "onCreateCommand": "bash .devcontainer/onCreateCommand.sh",

  "remoteUser": "vscode"
}
